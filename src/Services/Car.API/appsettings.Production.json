{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning"
        },
        "Console": {
            "IncludeScopes": true
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Host=postgres;Database=CarDb;Username=postgres;Port=5432;Pooling=true;"
    },
    "RabbitMQ": {
        "Host": "rabbitmq",
        "Port": 5672,
        "VirtualHost": "/",
        "RequestedHeartbeat": 60,
        "DispatchConsumersAsync": true
    },
    "Observability": {
        "EnableMetrics": true,
        "EnableTracing": true,
        "EnableLogs": true,
        "ServiceNamespace": "SagaPattern",
        "ServiceVersion": "1.0.0",
        "Otlp": {
            "Endpoint": "http://otel-collector:4318"
        }
    },
    "KeyVault": {
        "VaultUrl": "${KEY_VAULT_URL}",
        "UseManagedIdentity": true,
        "CacheDurationMinutes": 5
    }
}