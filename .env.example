# ============================================================================
# Local Development Environment Configuration
# ============================================================================
# Copy this file to .env and customize for your local environment
# This file is used by docker-compose.dev.yml
#
# IMPORTANT: Never commit real secrets to version control!
# Use this file only for LOCAL DEVELOPMENT
# ============================================================================

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=saga_db

# PostgreSQL Databases
POSTGRES_DATABASES=BookingDb,FlightDb,HotelDb,CarDb

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Application Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Observability
OTLP_ENDPOINT=http://otel-collector:4318
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d

# API Service Configuration
API_PORT=8080
API_REPLICA_COUNT=1

# Enable/Disable Features
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_LOGGING=true

# ============================================================================
# Dynatrace Configuration (Local Development)
# ============================================================================
# IMPORTANT: These are placeholder values. For local development, you can either:
# 1. Use mock credentials (OneAgent will log connection attempts without validating)
# 2. Provide real Dynatrace credentials (requires active Dynatrace environment)
#
# DO NOT COMMIT REAL CREDENTIALS TO VERSION CONTROL!

# Dynatrace Tenant ID or SaaS Cluster ID (e.g., "abc12345" or "xyz12345.live.dynatrace.com")
DT_TENANT=

# Full URL to your Dynatrace environment
# SaaS: https://{environment-id}.live.dynatrace.com
# Managed: https://{cluster-domain}/e/{environment-id}
DT_API_URL=

# Dynatrace API token for agent installation
# Generate in Dynatrace UI → Settings → Integration → Dynatrace API → Create Token
# Required scopes: app_monitoring, document_entities, entity_read
DT_API_TOKEN=

# Custom host identifier for local development environment
# Used to group monitoring data in Dynatrace (recommended: "saga-local-dev")
DT_HOST_ID=saga-local-dev
